APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000

POSTGRES_DB=macro_tracker
POSTGRES_USER=macro_user
POSTGRES_PASSWORD=macro_password
DATABASE_URL=postgresql+asyncpg://macro_user:macro_password@localhost:5432/macro_tracker
REDIS_URL=redis://localhost:6379/0

API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
INGESTION_HTTP_TIMEOUT_SECONDS=20
INGESTION_HTTP_USER_AGENT=macro-economic-tracker/0.1
INGESTION_SCHEDULE_INTERVAL_SECONDS=900
INGESTION_STARTUP_DELAY_SECONDS=10
INGESTION_PULL_LIMIT=10
INGESTION_SCHEDULE_SOURCES=fed_press,fed_speeches,ecb_press,bls_calendar

OPENAI_API_KEY=
